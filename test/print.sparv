print("Hello, World"); // expected: Hello, World

print(1); // expected: 1

print([1,2,3]); // expected: [1, 2, 3]

print(print); // expected: <native fn Print>

print(fun() {}); // expected: <function>

print(null); // expected: null

print(true); // expected: true

print({ i1 = 1, l1 = [1, 2, 3],}); // expected: {i1: 1, l1: [1, 2, 3]}
