import "test.gran";
fun get_list() {
    return [1,2,3];
}

fun square_list(list) {
    for i in 0:len list {
        list[i] = list[i] * list[i];
    }
    return list;
}

fun print_list(list) {
    print list;
    return list;
}

fun add(list) {
    for i in 0:len list {
        list[i] = list[i]+1;
    }
    return list;
}



